# =============================================================================
# Environment Variables Template
# =============================================================================
# Copy this file to .env and fill in the values for your local environment.
#   cp .env.example .env
#
# IMPORTANT: Never commit .env to version control.
# =============================================================================

# ---------------------------------------------------------------------------
# Redpanda / Kafka Connection
# ---------------------------------------------------------------------------

# Comma-separated list of broker addresses
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# Logical client identifier (helps trace messages in the broker logs)
KAFKA_CLIENT_ID=async-producer-dev

# Default topic prefix for all application topics
KAFKA_TOPIC_PREFIX=

# ---------------------------------------------------------------------------
# Producer Tuning
# ---------------------------------------------------------------------------

# Acknowledgement mode: 0 = none, 1 = leader only, "all" = full ISR
KAFKA_ACKS=all

# Compression algorithm: none | gzip | snappy | lz4 | zstd
KAFKA_COMPRESSION_TYPE=snappy

# Max time (ms) to buffer messages before sending — reduces round-trips
KAFKA_LINGER_MS=5

# Max bytes per batch sent to the broker in one request
KAFKA_MAX_BATCH_SIZE=65536

# Request timeout in milliseconds
KAFKA_REQUEST_TIMEOUT_MS=30000

# Maximum number of retry attempts on transient errors
KAFKA_MAX_RETRIES=3

# ---------------------------------------------------------------------------
# Schema Registry (optional — enable if using Avro/Protobuf schemas)
# ---------------------------------------------------------------------------

# SCHEMA_REGISTRY_URL=http://localhost:8081
# SCHEMA_REGISTRY_AUTH_USER=
# SCHEMA_REGISTRY_AUTH_PASSWORD=

# ---------------------------------------------------------------------------
# Observability
# ---------------------------------------------------------------------------

# Log level: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO

# Application environment tag (dev | staging | production)
APP_ENVIRONMENT=dev

# Service name emitted in structured log entries
APP_SERVICE_NAME=async-producer
